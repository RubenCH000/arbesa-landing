{
    "version": 2,
    "public": true,
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/admin",
            "dest": "/admin.html"
        },
        {
            "src": "/admin.html",
            "dest": "/admin.html"
        },
        {
            "src": "/checkout",
            "dest": "/checkout.html"
        },
        {
            "src": "/checkout.html",
            "dest": "/checkout.html"
        },
        {
            "src": "/confirmation",
            "dest": "/confirmation.html"
        },
        {
            "src": "/confirmation.html",
            "dest": "/confirmation.html"
        },
        {
            "src": "/css/(.*)",
            "dest": "/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/js/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}